obbSH   = input.string('First', 'Display Order Blocks & Breaker Blocks', options = ['All', 'First', 'Last'], group = grp_ob, display = disp)

bullOC  = input(color.new(#02c80a, 90), 'Order Blocks  : Bullish'   , inline = 'OBC', group = grp_ob)
bearOC  = input(color.new(#5e2395, 80), 'Bearish'   , inline = 'OBC', group = grp_ob)
