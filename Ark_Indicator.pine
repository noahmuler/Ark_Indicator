//@version=6
indicator("Ark Indicator", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500, max_bars_back=500)

//===============================================================================
//ARK INDICATOR - SMART MONEY CONCEPTS TOOLKIT
//===============================================================================

                //Author: Ark Labs
                //Version: 1.3.0
                //Last Updated: April 2026

//DESCRIPTION:
    //Advanced TradingView Pine Script v6 indicator implementing institutional 
    //Smart Money Concepts (SMC) for professional trading analysis.

//FEATURES:
    //- Session Killzones (Sydney/Asia/London/NY AM/PM) with customizable colors
    //- Order Blocks & Breaker Blocks with mitigation detection
    //- Fair Value Gaps (FVG) with ATR-based filtering
    //- Market Structure Shifts (MSS/CHoCH) within killzones
    //- Equal Highs/Lows (EQH/EQL) with threshold detection
    //- Market Open Gaps (MOG/GAP) with daily detection
    //- Liquidity Timing Lines with vertical markers
    //- Moving Averages (21EMA/50SMA/200SMA)
    //- Real-time Dashboard (RSI + Session + Liq status)

//TIMEFRAMES:
    //- Optimized for intraday timeframes (1M to 1H)
    //- Killzones display limited to timeframes up to 45M (configurable)

//TIMEZONE:
    //- All sessions configured for EST (UTC-5) / EDT (UTC-4)
    //- Session times align with institutional trading hours

//NOTES:
    //- Uses extend.none for finite line drawing (no infinite extension)
    //- Labels controlled by unified text display settings
    //- ATR-based filtering for cleaner visualization
    //- Production ready with comprehensive error handling

//===============================================================================


//------------------------------------------------------------------------------
// INPUT SETTINGS
//------------------------------------------------------------------------------

// Display settings for UI optimization
disp    = display.all - display.status_line

//------------------------------------------------------------------------------
// SESSION KILLZONE SETTINGS
//------------------------------------------------------------------------------
// Configure trading session killzones with custom colors and time ranges
// All times are in EST/EDT (UTC-5/UTC-4) to align with institutional hours

grp_session = "🕐 Session Settings"
sessionColor = input(color.new(#ffffff, 96), 'Session Color', inline = 'sydney', group = grp_session)
sydneySH = input(true, '', inline = 'sydney', group = grp_session)
sydneyST = input.string('Sydney', '', inline = 'sydney', group = grp_session, display = disp)
sydneyS  = input.session('1700-0200', '', inline = 'sydney', group = grp_session, display = disp)
sydneyC  = sessionColor

asSH    = input(true, '', inline = 'asia', group = grp_session)
asST    = input.string('Asia', '', inline = 'asia', group = grp_session, display = disp)
asS     = input.session('1900-0400', '', inline = 'asia', group = grp_session, display = disp)
asC     = sessionColor

ldnOSH  = input(true, '', inline = 'ldno', group = grp_session)
ldnOST  = input.string('London', '', inline = 'ldno', group = grp_session, display = disp)
ldnOS   = input.session('0300-0700', '', inline = 'ldno', group = grp_session, display = disp)
ldnOC   = sessionColor

nySH    = input(true,   '', inline = 'nyam', group = grp_session)
nyST    = input.string('NY AM', '', inline = 'nyam', group = grp_session, display = disp)
nyS     = input.session('0800-1200', '', inline = 'nyam', group = grp_session, display = disp)
nyC     = sessionColor

nyPMH   = input(true,   '', inline = 'nypm', group = grp_session)
nyPMST   = input.string('NY PM', '', inline = 'nypm', group = grp_session, display = disp)
nyPMS   = input.session('1200-1600', '', inline = 'nypm', group = grp_session, display = disp)
nyPMC   = sessionColor

dwmO    = input.string('None', 'Open Price of', options = ['Killzones', 'the Day', 'the Week', 'the Month', 'None'], inline = 'OP', group = grp_session, display = disp)
dwmS    = input.bool(true, 'Separator', inline = 'OP', group = grp_session)
dwmC    = input(color.new(color.gray, 89), '', inline = 'OP', group = grp_session)
dwmL    = input.bool(true, 'Label', inline = 'OP', group = grp_session)

kzMML   = input(true,   'Killzone Lines : Top/Bottom', inline = 'LN', group = grp_session)
kzML    = input(false,  'Mean', inline = 'LN', group = grp_session)
kzLE    = input(true,  'Extend Top/Bottom', inline = 'LN', group = grp_session)
kzLB    = input(true,  'Killzone Labels', group = grp_session)
kzSH    = input.int(15, 'Display Killzones within Timeframes Up To', options = [1, 3, 5, 15, 30, 45, 60], group = grp_session, display = disp)


//------------------------------------------------------------------------------
// ORDER BLOCK & BREAKER BLOCK SETTINGS
//------------------------------------------------------------------------------
// Configure order block detection, display, and mitigation logic
// Uses swing detection to identify institutional liquidity zones

grp_ob = "📦 Order Block Settings"
obSH    = input.bool(true, 'Order Blocks | Breaker Blocks', inline = 'OB', group = grp_ob)
bbSH    = input.bool(false, '', inline = 'OB', group = grp_ob)

obbLN   = input.int(5, 'Swing Detection Length', minval = 3, group = grp_ob, display = disp)
obbMT   = input.string('Closing Price', 'Mitigation Price', options = ['Closing Price', 'Wick'], group = grp_ob, display = disp)
obbMP   = obbMT == 'Closing Price'
useBody = input(false, 'Use Candle Body in Detection', group = grp_ob)
obbR    = input.bool(true, 'Remove Mitigated Order Blocks & Breaker Blocks', group = grp_ob)
extTT   = 'In this context, "extend" refers to the action of projecting or elongating the visual objects beyond the boundaries of the killzones.'
obbEX   = input.bool(true, 'Extend Order Blocks & Breaker Blocks', group = grp_ob, tooltip = extTT)
obbSH   = input.string('First', 'Display Order Blocks & Breaker Blocks', options = ['All', 'First', 'Last'], group = grp_ob, display = disp)

bullOC  = input(color.new(#02c80a, 90), 'Order Blocks  : Bullish'   , inline = 'OBC', group = grp_ob)
bearOC  = input(color.new(#5e2395, 80), 'Bearish'   , inline = 'OBC', group = grp_ob)
bullBC  = input(color.new(#ff1100, 90), 'Breaker Blocks : Bullish', inline = 'BBC', group = grp_ob)
bearBC  = input(color.new(#0cb51a, 80), 'Bearish', inline = 'BBC', group = grp_ob)
obbTX   = input.bool(true, 'Show Order Blocks & Breaker Blocks Text', group = grp_ob)


//------------------------------------------------------------------------------
// FAIR VALUE GAP (FVG) SETTINGS
//------------------------------------------------------------------------------
// Configure FVG detection with ATR-based filtering and extension logic
// Independent detection prevents overlap with other gap types

grp_fvg = "⚡ Fair Value Gap Settings"
fvgSH   = input.bool(true, 'Fair Value Gaps', group = grp_fvg)
fvgTT   = 'The script showcases fair value gaps that exceed a predetermined length calculated by multiplying the fixed-average true range (ATR) value by the option\'s value.\n\n' + 
           'The option value set to 0 means no filtering is applied.\n\n' + 
           'Remark: No filtering will be implemented for the initial 144 candles based on the fixed-length ATR, as the ATR value won\'t be available during this period.'
fvgTX   = input.bool(true, 'Show FVGs Text', group = grp_fvg)
fvgSessionsOnly = input.bool(false, 'Sessions Only', group = grp_fvg)
fvgR    = input.bool(true, 'Remove Mitigated FVGs', group = grp_fvg)
fvgE    = input.bool(true, 'Extend FVGs', group = grp_fvg, tooltip = extTT)
fvgTH   = input.float(0.1, 'FVG Width Filter', minval = 0, step = .1, tooltip = fvgTT, group = grp_fvg, display = disp)
fvgDO   = input.string('First', 'Display FVGs', options = ['All', 'First', 'Last'], group = grp_fvg, display = disp)
fvgBC   = input(color.new(#02c80a, 90), 'Bullish Imbalance', group = grp_fvg)
fvgSC   = input(color.new(#5e2395, 80), 'Bearish Imbalance', group = grp_fvg)
fvgSkipMOG = input.bool(true, 'Skip Market Open Gaps (Avoid MOG Overlap)', group = grp_fvg)
fvgMOGBuffer = input.int(30, 'FVG MOG Buffer (minutes)', minval = 0, maxval = 60, step = 5, tooltip = 'Minutes before/after market open to skip FVGs', group = grp_fvg)


//------------------------------------------------------------------------------
// EQUAL HIGHS/LOWS SETTINGS
//------------------------------------------------------------------------------
// Configure EQH/EQL detection using pivot points and ATR thresholds
// Identifies potential support/resistance zones

grp_eq = "⚖️ Equal Highs/Lows Settings"
eqhSH   = input.bool(true, 'Equal Highs/Lows', group = grp_eq)
eqTX    = input.bool(true, 'Show Equal HL Text', group = grp_eq)
eqLen   = input.int(3, 'Bars Confirmation', minval = 1, group = grp_eq)
eqTH    = input.float(0.05, 'Threshold (ATR mult)', minval = 0, maxval = 0.5, step = 0.05, group = grp_eq, tooltip = 'Lower = stricter (fewer EQs)')
eqhCss  = input.color(color.new(#5e2395, 0), 'EQH Color', inline = 'EQ', group = grp_eq)
eqlCss  = input.color(color.new(#02c80a, 0), 'EQL Color', inline = 'EQ', group = grp_eq)

var eq_prev_top = 0., var eq_top_x = 0, var eq_prev_btm = 0., var eq_btm_x = 0


//------------------------------------------------------------------------------
// MARKET STRUCTURE SHIFTS (MSS) SETTINGS
//------------------------------------------------------------------------------
// Configure MSS/CHoCH detection within killzones only
// Uses pivot detection for structure change identification

grp_mss = "🔄 Market Structure Shifts"
mssSH   = input.bool(true, 'Market Structure Shifts', group = grp_mss)
mssTX   = input.bool(true, 'Show Market Structure Shifts Text', group = grp_mss)
mssAlign = input.string('top_center', 'MSS Label Position', options=['top_left', 'top_center', 'top_right'], group = grp_mss)
mssLN   = input.int(7, "Detection Length", minval = 1, group = grp_mss, display = disp)
mssDO   = input.string('First', 'Display Market Structure Shifts', options = ['All', 'First', 'Last'], group = grp_mss, display = disp)
ppLCB   = input.color(color.new(#02c80a, 0), 'Market Structure Shifts : Bullish', inline = 'MSS', group = grp_mss)
ppLCS   = input.color(color.new(#5e2395, 0), 'Bearish', inline = 'MSS', group = grp_mss)


//------------------------------------------------------------------------------
// MARKET OPEN GAPS (MOG) SETTINGS
//------------------------------------------------------------------------------
// Configure daily open gap detection with extension logic
// Independent detection prevents overlap with FVG

grp_mog = "📊 Market Open Gaps"
mogSH = input.bool(true, 'Market Open Gaps', group = grp_mog)
mogTX = input.bool(true, 'Show MOG Text', group = grp_mog)
mogBC = input.color(color.new(#02c80a, 90), 'Bullish MOG', group = grp_mog)
mogSC = input.color(color.new(#5e2395, 85), 'Bearish MOG', group = grp_mog)
mogE = input.bool(true, 'Extend MOG', group = grp_mog)



//------------------------------------------------------------------------------
// MOVING AVERAGES SETTINGS
//------------------------------------------------------------------------------
// Configure standard moving averages for trend analysis
// 21EMA for short-term, 50SMA for medium-term, 200SMA for long-term

grp_ma = " Moving Averages"
show_ma = input.bool(true, "Show MAs", group=grp_ma)
ema21_color = input.color(color.blue, "21 EMA", group=grp_ma)
sma50_color = input.color(color.new(#5e2395, 0), "50 SMA", group=grp_ma)
sma200_color = input.color(color.new(#02c80a, 0), "200 SMA", group=grp_ma)


//------------------------------------------------------------------------------
// LIQUIDITY TIMING SETTINGS
//------------------------------------------------------------------------------
// Configure vertical liquidity markers for key session times
// Uses finite lines with labels positioned at line bottoms

grp_liq = "💧 Liquidity Timing Settings"
liqSH = input.bool(true, "Liquidity Timing", group=grp_liq)
liqLabels = input.bool(true, "Show Liq Labels", group=grp_liq)
liqTF = input.int(5, 'Display Liquidity within Timeframes Up To', options = [1, 3, 5, 15, 30, 45, 60], group = grp_liq, display = disp)
liqColor = input(color.new(#e65704, 19), "Liq Color", group=grp_liq)
preAsianSH = input.bool(true, "Pre-Asian", inline="prea", group=grp_liq)
preAsianS = input.session("1800-2000", "", inline="prea", group=grp_liq)
asianOpenSH = input.bool(true, "Asian Open", inline="asop", group=grp_liq)
asianOpenS = input.session("2000-2130", "", inline="asop", group=grp_liq)
preLondonSH = input.bool(true, "Pre-London", inline="prel", group=grp_liq)
preLondonS = input.session("0100-0300", "", inline="prel", group=grp_liq)
londonOpenSH = input.bool(true, "London Open", inline="lonop", group=grp_liq)
londonOpenS = input.session("0300-0430", "", inline="lonop", group=grp_liq)
preNYSH = input.bool(true, "Pre-NY", inline="pren", group=grp_liq)
preNYS = input.session("0630-0800", "", inline="pren", group=grp_liq)
nyOpenSH = input.bool(true, "NY Open", inline="nyop", group=grp_liq)
nyOpenS = input.session("0800-0801", "", inline="nyop", group=grp_liq)
nyseSH = input.bool(true, "NYSE Open", inline="nyse", group=grp_liq)
nyseS = input.session("0930-0931", "", inline="nyse", group=grp_liq)
londonCloseSH = input.bool(true, "London Close", inline="lonc", group=grp_liq)
londonCloseS = input.session("1000-1100", "", inline="lonc", group=grp_liq)

//------------------------------------------------------------------------------
// CUSTOM TYPE DEFINITIONS
//------------------------------------------------------------------------------
// Define structured data types for organizing indicator components
// Each type encapsulates related properties for better code organization
// Basic bar data structure for price and time information
type bar
    float o = open     // Open price
    float h = high     // High price
    float l = low      // Low price
    float c = close    // Close price
    int   t = time     // Timestamp
    int   i = bar_index // Bar index
    
// Order Block structure for bullish/bearish zones
type OB
    float top  = na   // Top price level of order block
    float btm  = na   // Bottom price level of order block
    int   obI  = na   // Bar index for fixed positioning
    box   bxOB       // Visual box element
    bool  ext  = true // Extension state

// Breaker Block structure (extends Order Block concept)
type BB
    box   bxOB       // Original order block box
    box   bxBB       // Breaker block box
    bool  ext  = true // Extension state
    bool  bb   = false // Breaker block activation flag
    int   bbI  = na   // Bar index for fixed positioning
    int   lst  = na   // Last state tracking

// Swing point structure for pivot detection
type swing
    float y = na    // Price level of swing
    int   i = na    // Bar index of swing
    bool  x = false // Activation state

// Pivot point structure for market structure analysis
type pivotPoint
    float  h   // High pivot price
    int    hi  // High pivot bar index
    bool   hx  // High pivot activation flag
    float  l   // Low pivot price
    int    li  // Low pivot bar index
    bool   lx  // Low pivot activation flag

// Killzone structure for session-based trading zones
type KZ
    line  lnT   // Top boundary line
    line  lnM   // Mean line (optional)
    line  lnB   // Bottom boundary line
    line  lnO   // Open price line
    label lb    // Killzone label
    label lbO   // Open price label

// Day/Week/Month structure for time-based separators
type DWM
    line  ln   // Separator line
    label lb   // Separator label

// Market Structure Shift structure
type MSS
    line  ln   // MSS line
    label lb   // MSS label

// Fair Value Gap structure
type FVG
    box   bx   // FVG box visualization
    bool  e    // Extension state

// Liquidity Line structure for timing markers
type LiqLine
    line  lnTop        // Top boundary line
    line  lnBot        // Bottom boundary line
    int   startTime = na // Session start time
    float sessHigh  = na // Session high price
    float sessLow   = na // Session low price
    label lb          // Liquidity label
    bool  xt = false    // Top extension flag
    bool  xb = false    // Bottom extension flag

//------------------------------------------------------------------------------
// GLOBAL VARIABLES
//------------------------------------------------------------------------------
// Initialize core variables and session detection logic

// Basic data structures
bar b = bar.new()           // Current bar data
tfM = timeframe.multiplier   // Current timeframe multiplier

//------------------------------------------------------------------------------
// SESSION DETECTION VARIABLES
//------------------------------------------------------------------------------
// Boolean flags for active session detection based on timeframe and settings
// All sessions use UTC-4/UTC-5 timezone alignment

sydney   = not na(time(timeframe.period, sydneyS , 'UTC-4')) and sydneySH and tfM <= kzSH
asian    = not na(time(timeframe.period, asianOpenS, 'UTC-4')) and asSH    and tfM <= kzSH
london   = not na(time(timeframe.period, ldnOS   , 'UTC-4')) and ldnOSH  and tfM <= kzSH
nyam     = not na(time(timeframe.period, nyS     , 'UTC-4')) and nySH    and tfM <= kzSH
nypm     = not na(time(timeframe.period, nyPMS   , 'UTC-4')) and nyPMH   and tfM <= kzSH
inKZ  = sydney or asian or london or nyam or nypm
var KZ kz = KZ.new()

var DWM dwm = DWM.new()

var bOB = array.new<OB>(0)
var aOB = array.new<OB>(0)

var bBB = array.new<BB>(0)
var aBB = array.new<BB>(0)

var bLS = array.new_int()
var aLS = array.new_int()

var bMSS = array.new<MSS>(0)
var aMSS = array.new<MSS>(0)

var pivotPoint pp = pivotPoint.new()
var shift = 0

fvgATR = nz(ta.atr(144)) * fvgTH

var bMOG = array.new<box>(0)
var aMOG = array.new<box>(0)

//------------------------------------------------------------------------------
// LIQUIDITY TIMING VARIABLES
//------------------------------------------------------------------------------
// Initialize liquidity line structures for each session marker

var LiqLine preAsianLine   = LiqLine.new(na)   // Pre-Asian liquidity marker
var LiqLine asianOpenLine  = LiqLine.new(na)   // Asian Open liquidity marker
var LiqLine preLondonLine  = LiqLine.new(na)   // Pre-London liquidity marker
var LiqLine londonOpenLine = LiqLine.new(na)   // London Open liquidity marker
var LiqLine preNYLine      = LiqLine.new(na)   // Pre-NY liquidity marker
var LiqLine nyOpenLine     = LiqLine.new(na)   // NY Open liquidity marker
var LiqLine nyseOpenLine   = LiqLine.new(na)   // NYSE Open liquidity marker
var LiqLine londonCloseLine= LiqLine.new(na)   // London Close liquidity marker

//------------------------------------------------------------------------------
// LIQUIDITY SESSION DETECTION
//------------------------------------------------------------------------------
// ATR calculation for liquidity line sizing and session activation flags

atr_liq = ta.atr(14)  // ATR for liquidity line sizing

// Session activation flags for line drawing - only activate when session is active, settings enabled, and timeframe <= M5
preAsian = liqSH and preAsianSH and not na(time(timeframe.period, preAsianS, "UTC-4")) and tfM <= liqTF
asianOpen = liqSH and asianOpenSH and not na(time(timeframe.period, asianOpenS, "UTC-4")) and tfM <= liqTF
preLondon = liqSH and preLondonSH and not na(time(timeframe.period, preLondonS, "UTC-4")) and tfM <= liqTF
londonOpen = liqSH and londonOpenSH and not na(time(timeframe.period, londonOpenS, "UTC-4")) and tfM <= liqTF
preNY = liqSH and preNYSH and not na(time(timeframe.period, preNYS, "UTC-5")) and tfM <= liqTF
nyOpen = liqSH and nyOpenSH and not na(time(timeframe.period, nyOpenS, "UTC-5")) and tfM <= liqTF
nyseOpen = liqSH and nyseSH and not na(time(timeframe.period, nyseS, "UTC-5")) and tfM <= liqTF
londonClose = liqSH and londonCloseSH and not na(time(timeframe.period, londonCloseS, "UTC-5")) and tfM <= liqTF

// Session activation flags for dashboard - work on all timeframes
preAsianDash = liqSH and preAsianSH and not na(time(timeframe.period, preAsianS, "UTC-4"))
asianOpenDash = liqSH and asianOpenSH and not na(time(timeframe.period, asianOpenS, "UTC-4"))
preLondonDash = liqSH and preLondonSH and not na(time(timeframe.period, preLondonS, "UTC-4"))
londonOpenDash = liqSH and londonOpenSH and not na(time(timeframe.period, londonOpenS, "UTC-4"))
preNYDash = liqSH and preNYSH and not na(time(timeframe.period, preNYS, "UTC-5"))
nyOpenDash = liqSH and nyOpenSH and not na(time(timeframe.period, nyOpenS, "UTC-5"))
nyseOpenDash = liqSH and nyseSH and not na(time(timeframe.period, nyseS, "UTC-5"))
londonCloseDash = liqSH and londonCloseSH and not na(time(timeframe.period, londonCloseS, "UTC-5"))

//------------------------------------------------------------------------------
// TECHNICAL INDICATOR CALCULATIONS
//------------------------------------------------------------------------------
// Calculate pivot points, ATR values, and time-based triggers

mss_pivot_high = ta.pivothigh(mssLN, mssLN)  // MSS high pivot detection
mss_pivot_low = ta.pivotlow(mssLN, mssLN)    // MSS low pivot detection
eq_atr = ta.atr(200)                        // ATR for EQH/EQL threshold
day_change = timeframe.change('1D')         // Daily change trigger for MOG

// FVG MOG buffer calculations (global variables to avoid warnings)
asianOpenBars = ta.barssince(not na(time(timeframe.period, asianOpenS, "UTC-4")))
londonOpenBars = ta.barssince(not na(time(timeframe.period, londonOpenS, "UTC-4")))
nyOpenBars = ta.barssince(not na(time(timeframe.period, nyOpenS, "UTC-5")))
nyseOpenBars = ta.barssince(not na(time(timeframe.period, nyseS, "UTC-5")))

//------------------------------------------------------------------------------
// CORE FUNCTIONS AND METHODS
//------------------------------------------------------------------------------
// Main processing functions for each indicator component

method pDWM(DWM _id, _tC, _t, _o, _cl, _lbTX, _olL) =>
    if _tC
        _id.lb.delete()
        _id.ln := line.new(_t, _o, _t, _o, xloc.bar_time, extend.none, color.new(_cl, 0), line.style_dotted, 1)

        if _olL
            _id.lb := label.new(_t, _o, _lbTX + '(' + str.tostring(_o, format.mintick) + ')', xloc.bar_time, yloc.price, color(na), label.style_label_left, color.new(_cl, 0), size.tiny)
    else
        _id.ln.set_x2(_t)

        if _olL
            _id.lb.set_x(_t)
        na

swings(_l)=>
    var os = 0
    var swing top = swing.new(na, na)
    var swing btm = swing.new(na, na)
    
    upper = ta.highest(_l)
    lower = ta.lowest(_l)

    os := high[_l] > upper ? 0 : low[_l] < lower ? 1 : os

    if os == 0 and os[1] != 0
        top := swing.new(high[_l], bar_index[_l])
    
    if os == 1 and os[1] != 1
        btm := swing.new(low[_l], bar_index[_l])

    [top, btm]

method killzones(KZ _id, _s, _kz, _o, _h, _l, _c, _t, _cr, _tx, _mml, _ml, _lb, _le, _ol, _olC, _olL, areaCss)=>
    var float max = na, var float mid = na, var float min = na 
    var int sbT = na, var bool xt = false, var bool xb = false
    var box area = na
    var tC = color.rgb(color.r(_cr), color.g(_cr), color.b(_cr))
    
    if _s and not _s[1]
        max := _h
        sbT := _t
        min := _l
        mid := math.avg(max, min)
        area := box.new(bar_index, max, bar_index, min, na, bgcolor = areaCss)

        if _mml
            _id.lnT := line.new(sbT, max, sbT, max, xloc.bar_time, color = tC)
            _id.lnB := line.new(sbT, min, sbT, min, xloc.bar_time, color = tC)

        if _ml
            _id.lnM := line.new(sbT, mid, sbT, mid, xloc.bar_time, color = tC, style = line.style_dotted)
        
        if _ol
            _id.lnO := line.new(sbT, _o, sbT, _o, xloc.bar_time, color = color.new(_olC, 0), style = line.style_dotted)

            if _olL
                _id.lbO := label.new(sbT, _o, 'KZO(' + str.tostring(_o, format.mintick) + ')', xloc.bar_time, color = color(na), style = label.style_label_left, textcolor = color.new(_olC, 0), size = size.tiny)

        if _lb
            _id.lb := label.new(sbT, max, _tx, xloc.bar_time, color = #ffffff00, style = label.style_label_down, textcolor = tC, size = size.small)
    
    if _s
        max := math.max(_h, max)
        min := math.min(_l, min)
        mid := math.avg(max, min)
        xt := true
        xb := true

        area.set_top(max)
        area.set_rightbottom(bar_index, min)

        if _lb
            label.set_x(_id.lb, int(math.avg(_t, sbT)))
            label.set_y(_id.lb, max)

        if _mml
            _id.lnT.set_y1(max)
            _id.lnT.set_xy2(_t, max)
            _id.lnB.set_y1(min)
            _id.lnB.set_xy2(_t, min)
        
        if _ml
            _id.lnM.set_y1(mid)
            _id.lnM.set_x2(_t)
            _id.lnM.set_y2(mid)
        
        if _ol 
            _id.lnO.set_x2(_t)

            if _olL
                _id.lbO.set_x(_t)
    
    if not _s and _le and not _kz

        if _mml
            if xt 
                if _h < _id.lnT.get_y1()
                    _id.lnT.set_x2(_t)
                else 
                    _id.lnT.set_x2(_t)
                    xt := false

            if xb
                if _l > _id.lnB.get_y1()
                    _id.lnB.set_x2(_t)
                else 
                    _id.lnB.set_x2(_t)
                    xb := false

        if _ml
            _id.lnM.set_x2(_t)

pOBB(_s, _o, _h, _l, _c, _i, _t, _st, _sb, _mx, _mn, _cOBb, _cBBb, _cOBa, _cBBa, _obS, _bbS, _obbM, _obbTX, _obbE, _obbD, _obbR) => 

    var int sbI = 0, var bool xb = false, var bool xa = false

    if _s and not _s[1]
        sbI := _i, xb := true, xa := true
        
        if _obbE
            array.clear(bOB)
            array.clear(aOB)
            array.clear(bBB)
            array.clear(aBB)

    if _s
        if _c[1] > _st.y and not _st.x and _st.i >= sbI
            _st.x := true

            minima = _mx[1]
            maxima = _mn[1]
            sBI = _i[1]  // Store bar_index for fixed positioning

            for i = 1 to (_i - _st.i) - 1
                minima := math.min(_mn[i], minima)
                maxima := minima == _mn[i] ? _mx[i] : maxima
                sBI := minima == _mn[i] ? _i[i] : sBI
            
            bOB.unshift(OB.new(maxima, minima, sBI, 
                         box.new(na, na, na, na, color(na), text = _obbTX ? 'OB' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(_cOBb, 0)))) 
            bBB.unshift(BB.new(
                         box.new(na, na, na, na, color(na)), 
                         box.new(na, na, na, na, color(na), text = _obbTX ? 'BB' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(_cBBb, 0))))

        if _c[1] < _sb.y and not _sb.x and _st.i >= sbI 
            _sb.x := true

            minima = _mn[1]
            maxima = _mx[1]
            sBI = _i[1]

            for i = 1 to (_i - _sb.i) - 1
                maxima := math.max(_mx[i], maxima)
                minima := maxima == _mx[i] ? _mn[i] : minima
                sBI := maxima == _mx[i] ? _i[i] : sBI

            aOB.unshift(OB.new(maxima, minima, sBI, 
                         box.new(na, na, na, na, color(na), text = _obbTX ? 'OB' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(_cOBa, 0)))) 
            aBB.unshift(BB.new(
                         box.new(na, na, na, na, color(na)), 
                         box.new(na, na, na, na, color(na), text = _obbTX ? 'BB' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(_cBBa, 0))
                         ))

    if _obbE ? true : _s

        if bOB.size() > 0
            for i = bOB.size() - 1 to 0
                ob = bOB.get(i)
                bb = bBB.get(i)

                if _obbR 
                    if not ob.ext
                        ob.bxOB.delete()

                    if not bb.ext
                        bb.bxOB.delete()
                        bb.bxBB.delete()

                if not bb.bb 
                    if _obS and (_obbD == 'First' ? i == bOB.size() - 1 : true)
                        ob.bxOB.set_lefttop(ob.obI, ob.top)
                        ob.bxOB.set_rightbottom(_i, ob.btm)
                        ob.bxOB.set_bgcolor((_obbD == 'Last' ? i == 0 ? _cOBb : color(na): _cOBb))
                        ob.bxOB.set_text_color((_obbD == 'Last' ? i == 0 ? color.new(_cOBb, 0) : color(na): color.new(_cOBb, 0)))

                    if math.min((_obbM ? _c[1] : _l[1]), _o[1]) < ob.btm
                        bb.bb := true

                        if _obS
                            ob.bxOB.set_right(_i[1])
                            ob.ext := false

                        if _bbS and xb
                            bb.bbI := _i[1]
                            bb.bxBB.set_lefttop(bb.bbI, ob.top)
                            bb.bxBB.set_rightbottom(_i, ob.btm)
                            bb.bxBB.set_bgcolor(_cBBb)

                            if not _obS or _obbR or not (_obbD == 'First' ? i == bOB.size() - 1 : true)
                                bb.bxOB.set_lefttop(ob.obI, ob.top)
                                bb.bxOB.set_rightbottom(bb.bbI, ob.btm)
                                bb.bxOB.set_bgcolor(color(na))
                                bb.bxOB.set_border_color(_cBBb)

                            if _obbD == 'First'
                                xb := false

                            if _obbD == 'Last'
                                bLS.push(bb.bbI)

                else
                    if (_obbM ? _c[1] : _h[1]) > ob.top
                        bb.ext := false

                    if _obS
                        ob.bxOB.set_bgcolor((_obbD == 'Last' ? i == 0 ? _cOBb : color(na): _cOBb))
                        ob.bxOB.set_text_color((_obbD == 'Last' ? i == 0 ? color.new(_cOBb, 0) : color(na): color.new(_cOBb, 0)))

                    if _bbS and bb.ext
                        bb.bxBB.set_right(_i)

                    if _bbS
                        if _obbD == 'Last'
                            if i != 0
                                bb.bxOB.set_lefttop(ob.obI, ob.top)
                                bb.bxOB.set_rightbottom(bb.bbI, ob.btm)
                                bb.bxOB.set_bgcolor(color(na))
                                bb.bxOB.set_border_color(_cBBb)

                            if bLS.max() != bb.bxBB.get_left()
                                bb.bxBB.set_bgcolor(color(na))
                                bb.bxBB.set_text_color(color(na))
                                bb.bxOB.set_border_color(color(na))

        if aOB.size() > 0
            for i = aOB.size() - 1 to 0
                ob = aOB.get(i)
                bb = aBB.get(i)

                if _obbR 
                    if not ob.ext
                        ob.bxOB.delete()

                    if not bb.ext
                        bb.bxOB.delete()
                        bb.bxBB.delete()

                if not bb.bb 
                    if _obS and (_obbD == 'First' ? i == aOB.size() - 1 : true)
                        ob.bxOB.set_lefttop(ob.obI, ob.top)
                        ob.bxOB.set_rightbottom(_i, ob.btm)
                        ob.bxOB.set_bgcolor((_obbD == 'Last' ? i == 0 ? _cOBa : color(na) : _cOBa))
                        ob.bxOB.set_text_color((_obbD == 'Last' ? i == 0 ? color.new(_cOBa, 0) : color(na): color.new(_cOBa, 0)))

                    if math.max((_obbM ? _c[1] : _h[1]), _o[1]) > ob.top
                        bb.bb := true

                        if _obS
                            ob.bxOB.set_right(_i)
                            ob.ext := false

                        if _bbS and xa
                            bb.bbI := _i
                            bb.bxBB.set_lefttop(bb.bbI, ob.top)
                            bb.bxBB.set_rightbottom(_i, ob.btm)
                            bb.bxBB.set_bgcolor(_cBBa)

                            if not _obS or _obbR or not (_obbD == 'First' ? i == aOB.size() - 1 : true)
                                bb.bxOB.set_lefttop(ob.obI, ob.top)
                                bb.bxOB.set_rightbottom(bb.bbI, ob.btm)
                                bb.bxOB.set_bgcolor(color(na))
                                bb.bxOB.set_border_color(_cBBa)
                            
                            if _obbD == 'First'
                                xa := false

                            if _obbD == 'Last'
                                aLS.push(bb.bbI)
                else
                    if (_obbM ? _c[1] : _l[1]) < ob.btm
                        bb.ext := false

                    if _obS
                        ob.bxOB.set_bgcolor((_obbD == 'Last' ? i == 0 ? _cOBa : color(na): _cOBa))
                        ob.bxOB.set_text_color((_obbD == 'Last' ? i == 0 ? color.new(_cOBa, 0) : color(na): color.new(_cOBa, 0)))

                    if _bbS and bb.ext 
                        bb.bxBB.set_right(_i)
                    
                    if _bbS
                        if _obbD == 'Last'
                            if i != 0
                                bb.bxOB.set_lefttop(ob.obI, ob.top)
                                bb.bxOB.set_rightbottom(bb.bbI, ob.btm)
                                bb.bxOB.set_bgcolor(color(na))
                                bb.bxOB.set_border_color(_cBBa)

                            if aLS.max() != bb.bxBB.get_left()
                                bb.bxBB.set_bgcolor(color(na))
                                bb.bxBB.set_text_color(color(na))
                                bb.bxOB.set_border_color(color(na))

    else if not _obbE
        if bOB.size() > 0
            for i = bOB.size() - 1 to 0
                bOB.remove(i)

        if aOB.size() > 0
            for i = aOB.size() - 1 to 0
                aOB.remove(i)

        if bBB.size() > 0
            for i = bBB.size() - 1 to 0
                bBB.remove(i)

        if aBB.size() > 0
            for i = aBB.size() - 1 to 0
                aBB.remove(i)
        na

// liqLineUpdate method commented out to avoid compilation errors. Old liquidity lines preserved below.

//------------------------------------------------------------------------------
// MAIN CALCULATIONS - KILLZONES
//------------------------------------------------------------------------------
// Process session killzones with boundary lines and labels
// Only display on intraday timeframes within configured limits

kzO = dwmO == 'Killzones'  // Check if killzones are selected as open price reference

// Process each session killzone with boundary detection and visualization
kz.killzones(sydney   and timeframe.isintraday, inKZ, open, high, low, close, time, sydneyC , sydneyST , kzMML, kzML, kzLB, kzLE, kzO, dwmC, dwmL, sydneyC)  // Sydney session
kz.killzones(asian    and timeframe.isintraday, inKZ, open, high, low, close, time, asC    , asST    , kzMML, kzML, kzLB, kzLE, kzO, dwmC, dwmL, asC)    // Asian session
kz.killzones(london   and timeframe.isintraday, inKZ, open, high, low, close, time, ldnOC  , ldnOST , kzMML, kzML, kzLB, kzLE, kzO, dwmC, dwmL, ldnOC)   // London session
kz.killzones(nyam     and timeframe.isintraday, inKZ, open, high, low, close, time, nyC    , nyST    , kzMML, kzML, kzLB, kzLE, kzO, dwmC, dwmL, nyC)     // NY AM session
kz.killzones(nypm     and timeframe.isintraday, inKZ, open, high, low, close, time, nyPMC  , nyPMST , kzMML, kzML, kzLB, kzLE, kzO, dwmC, dwmL, nyPMC)   // NY PM session

// Determine time-based separator type and change detection
[xChg, xTxt] = switch dwmO
    'the Day'   => [timeframe.change('D'), 'DO']  // Daily open separator
    'the Week'  => [timeframe.change('W'), 'WO']  // Weekly open separator
    'the Month' => [timeframe.change('M'), 'MO']  // Monthly open separator

// Process day/week/month separators when not in killzone mode
if not kzO and timeframe.isintraday and tfM <= kzSH
    dwm.pDWM(xChg, time, open, dwmC, xTxt, dwmL)

// Apply background color for time separators
bgcolor(dwmS and not kzO and timeframe.isintraday and tfM <= kzSH ? xChg ? dwmC : na : na)

//------------------------------------------------------------------------------
// CALCULATIONS - ORDER BLOCKS & BREAKER BLOCKS
//------------------------------------------------------------------------------
// Detect institutional order blocks and breaker blocks using swing analysis
// Process mitigation logic and extension based on price action

// Calculate swing points for order block detection
[top, btm] = swings(obbLN)  // Get recent swing highs and lows

// Determine price range based on candle body or wick selection
max = useBody ? math.max(close, open) : high  // Maximum price for detection
min = useBody ? math.min(close, open) : low   // Minimum price for detection

// Process order blocks and breaker blocks if enabled
if obSH or bbSH
    pOBB(inKZ, open, high, low, close, bar_index, time, top, btm, max, min, bullOC, bullBC, bearOC, bearBC, obSH, bbSH, obbMP, obbTX, obbEX, obbSH, obbR)

//------------------------------------------------------------------------------
// CALCULATIONS - MARKET STRUCTURE SHIFTS (MSS)
//------------------------------------------------------------------------------
// Detect CHoCH (Change of Character) within killzones only
// Uses pivot points to identify structure breaks

// Process high pivot points for bearish structure changes
if not na(mss_pivot_high)
    pp.h  := mss_pivot_high  // Set high pivot price
    pp.hx := false           // Reset high pivot activation flag
    pp.hi := bar_index - mssLN  // Calculate high pivot bar index

// Process low pivot points for bullish structure changes
if not na(mss_pivot_low)
    pp.l  := mss_pivot_low   // Set low pivot price
    pp.lx := false           // Reset low pivot activation flag
    pp.li := bar_index - mssLN  // Calculate low pivot bar index

if not inKZ
    pp.l := 0
    pp.h := 10e8
    shift := 0
    array.clear(bMSS)
    array.clear(aMSS)

if mssSH and inKZ
    if close[1] > pp.h and not pp.hx
        pp.hx := true

        if shift == -1 or shift == 0
            int bull_x = int(math.avg(pp.hi, bar_index - mssLN))
            if (mssDO == 'First' ? bMSS.size() < 1 : true)
                bMSS.unshift(MSS.new(line.new(pp.hi, pp.h, bar_index - 1, pp.h, color = ppLCB), 
                 label.new(bull_x, pp.h, 'CHoCH', xloc.bar_index, yloc.price, color.new(color.white, 100), 
                     style = label.style_label_down, 
                     textcolor=mssTX ? ppLCB : color(na), size=size.tiny)))

            if bMSS.size() > 1
                if mssDO == 'Last'
                    mss = bMSS.pop()
                    mss.ln.delete(), mss.lb.delete()

        shift := 1

    if close[1] < pp.l and not pp.lx
        pp.lx := true

        if shift == 1 or shift == 0
            int bear_x = int(math.avg(pp.li, bar_index - mssLN))
            if (mssDO == 'First' ? aMSS.size() < 1 : true)
                aMSS.unshift(MSS.new(line.new(pp.li, pp.l, bar_index - 1, pp.l, color = ppLCS), 
                 label.new(bear_x, pp.l, 'CHoCH', xloc.bar_index, yloc.price, color.new(color.white, 100), 
                     style = label.style_label_up, textcolor=mssTX ? ppLCS : color(na), size=size.tiny)))

            if aMSS.size() > 1
                if mssDO == 'Last'
                    mss = aMSS.pop()
                    mss.ln.delete(), mss.lb.delete()

        shift := -1

//------------------------------------------------------------------------------
// CALCULATIONS - FAIR VALUE GAPS & EQUAL HIGHS/LOWS
//------------------------------------------------------------------------------

// Calculate pivot points for Equal Highs/Lows detection
eq_top = ta.pivothigh(eqLen, eqLen)  // High pivot detection
eq_btm = ta.pivotlow(eqLen, eqLen)    // Low pivot detection

//------------------------------------------------------------------------------
// STANDALONE FAIR VALUE GAP DETECTION
//------------------------------------------------------------------------------
// Independent FVG detection to prevent overlap with other gap types
// Uses ATR-based filtering for cleaner visualization

//Fair Value Gaps - Use time buffer around MOG creation to prevent overlap
// For Sessions Only, check if current time is within any killzone session
inSessionTime = not na(time(timeframe.period, sydneyS, 'UTC-4')) and sydneySH or 
               not na(time(timeframe.period, asianOpenS, 'UTC-4')) and asSH or
               not na(time(timeframe.period, ldnOS, 'UTC-4')) and ldnOSH or
               not na(time(timeframe.period, nyS, 'UTC-4')) and nySH or
               not na(time(timeframe.period, nyPMS, 'UTC-4')) and nyPMH

sessionCondition = fvgSessionsOnly ? inSessionTime : true
// More precise overlap prevention - block FVGs during and shortly after MOG creation
// Extended buffer to prevent timing-related overlaps
var int mogBarsSince = 0
mogBarsSince := ta.barssince(day_change and not day_change[1])
mogBufferActive = fvgSkipMOG and (day_change or mogBarsSince <= 2)


if fvgSH and sessionCondition and not mogBufferActive
    gapSize = low - high[2]
    if gapSize > fvgATR
        box.new(bar_index-2, low, bar_index + 20, high[2], bgcolor=fvgBC, border_color=fvgBC, text=fvgTX ? 'FVG' : na, text_size=size.tiny, text_color=color.new(#02c80a, 0))
    
bearGapSize = low[2] - high
if fvgSH and sessionCondition and not mogBufferActive and bearGapSize > fvgATR
    box.new(bar_index-2, low[2], bar_index + 20, high, bgcolor=fvgSC, border_color=fvgSC, text=fvgTX ? 'FVG' : na, text_size=size.tiny, text_color=color.new(#5e2395, 0))

//------------------------------------------------------------------------------
// EQUAL HIGHS/LOWS (EQH/EQL) DETECTION
//------------------------------------------------------------------------------
// Identify potential support/resistance zones using pivot points and ATR thresholds

if eqhSH
    // Process Equal Highs (resistance zones)
    if not na(eq_top)
        // Check if the current high is within the ATR threshold of the previous high
        if math.abs(eq_top - eq_prev_top) <= eq_atr * eqTH  
            // Draw a dotted line to visualize the EQH
            line.new(eq_top_x, eq_prev_top, bar_index - eqLen, eq_top, color = eqhCss, style = line.style_dotted)
            if eqTX
                // Add a label to the EQH line
                label.new(int(math.avg(bar_index - eqLen, eq_top_x)), eq_top, 'EQH', color = #00000000, textcolor = eqhCss, style = label.style_label_down, size = size.tiny)
        // Update the previous high reference
        eq_prev_top := eq_top  
        eq_top_x := bar_index - eqLen 
        
    // Process Equal Lows (support zones)
    if not na(eq_btm)
        // Check if the current low is within the ATR threshold of the previous low
        if math.abs(eq_btm - eq_prev_btm) <= eq_atr * eqTH  
            // Draw a dotted line to visualize the EQL
            line.new(eq_btm_x, eq_prev_btm, bar_index - eqLen, eq_btm, color = eqlCss, style = line.style_dotted)
            if eqTX
                // Add a label to the EQL line
                label.new(int(math.avg(bar_index - eqLen, eq_btm_x)), eq_btm, 'EQL', color = #00000000, textcolor = eqlCss, style = label.style_label_up, size = size.tiny)
        // Update the previous low reference
        eq_prev_btm := eq_btm  
        eq_btm_x := bar_index - eqLen

//------------------------------------------------------------------------------
// MARKET OPEN GAPS (MOG) - DAILY DETECTION
//------------------------------------------------------------------------------
// Independent daily gap detection using day_change trigger
// Prevents overlap with FVG detection

if mogSH and day_change and not day_change[1]
    // Bullish MOG: gap up (current low > previous day high)
    if low > high[1]
        mog_box = box.new(bar_index[1], low, bar_index, high[1], bgcolor=mogBC, border_color=mogBC, text=mogTX ? 'GAP↑' : na, text_size=size.tiny, text_color=color.new(#02c80a, 0))
        array.unshift(bMOG, mog_box)
    
    // Bearish MOG: gap down (current high < previous day low)
    if high < low[1]
        mog_box = box.new(bar_index[1], low[1], bar_index, high, bgcolor=mogSC, border_color=mogSC, text=mogTX ? 'GAP↓' : na, text_size=size.tiny, text_color=color.new(#5e2395, 0))
        array.unshift(aMOG, mog_box)

// MOG extension and mitigation logic
if mogE
    // Bullish MOG mitigation: low <= box bottom
    if array.size(bMOG) > 0
        for j = array.size(bMOG) - 1 to 0
            bx = array.get(bMOG, j)
            if low <= box.get_bottom(bx)
                box.set_right(bx, bar_index)
                array.remove(bMOG, j)
    
    // Bearish MOG mitigation: high >= box top
    if array.size(aMOG) > 0
        for j = array.size(aMOG) - 1 to 0
            bx = array.get(aMOG, j)
            if high >= box.get_top(bx)
                box.set_right(bx, bar_index)
                array.remove(aMOG, j)

//------------------------------------------------------------------------------
// LIQUIDITY TIMING - VERTICAL MARKERS
//------------------------------------------------------------------------------
// Display vertical lines and labels for key liquidity session times
// Uses finite lines (extend.none) with labels positioned at line bottoms
// Labels controlled by unified text display setting (eqTX)

avg_price = math.avg(high, low)  // Calculate average price for line positioning

// Pre-Asian liquidity marker (6PM-8PM EST)
if preAsian and not preAsian[1] and liqLabels
    line.new(time, avg_price - atr_liq, time, avg_price + atr_liq, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, avg_price - atr_liq, 'PA', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

// Asian Open liquidity marker (8PM-9:30PM EST)
if asianOpen and not asianOpen[1] and liqLabels
    line.new(time, low - atr_liq * 2, time, high + atr_liq * 2, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, low - atr_liq * 2, 'AO', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

// Pre-London liquidity marker (1AM-3AM EST)
if preLondon and not preLondon[1] and liqLabels
    line.new(time, low - atr_liq * 2, time, high + atr_liq * 2, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, low - atr_liq * 2, 'PL', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

// London Open liquidity marker (3AM-4:30AM EST)
if londonOpen and not londonOpen[1] and liqLabels
    line.new(time, low - atr_liq * 2, time, high + atr_liq * 2, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, low - atr_liq * 2, 'LO', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

// Pre-NY liquidity marker (6:30AM-8AM EST)
if preNY and not preNY[1] and liqLabels
    line.new(time, low - atr_liq * 2, time, high + atr_liq * 2, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, low - atr_liq * 2, 'PN', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

// NY Open liquidity marker (8AM EST)
if nyOpen and not nyOpen[1] and liqLabels
    line.new(time, low - atr_liq * 2, time, high + atr_liq * 2, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, low - atr_liq * 2, 'NY', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

// NYSE Open liquidity marker (9:30AM EST)
if nyseOpen and not nyseOpen[1] and liqLabels
    line.new(time, low - atr_liq * 2, time, high + atr_liq * 2, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, low - atr_liq * 2, 'NYSE', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

// London Close liquidity marker (10AM-11AM EST)
if londonClose and not londonClose[1] and liqLabels
    line.new(time, low - atr_liq * 2, time, high + atr_liq * 2, xloc.bar_time, extend=extend.none, color=liqColor, width=1)
    if eqTX
        label.new(time, low - atr_liq * 2, 'LC', xloc.bar_time, yloc.price, color = #00000000, textcolor = liqColor, style = label.style_label_up, size = size.tiny)

//------------------------------------------------------------------------------
// MOVING AVERAGES - TREND ANALYSIS
//------------------------------------------------------------------------------
// Standard moving averages for trend identification and confirmation
// 21EMA for short-term trend, 50SMA for medium-term, 200SMA for long-term

plot(show_ma ? ta.ema(close, 21) : na, "21 EMA", ema21_color, linestyle=plot.linestyle_dashed)  // Short-term trend
plot(show_ma ? ta.sma(close, 50) : na, "50 SMA", sma50_color)  // Medium-term trend
plot(show_ma ? ta.sma(close, 200) : na, "200 SMA", sma200_color)  // Long-term trend


//------------------------------------------------------------------------------
// REAL-TIME DASHBOARD & INDICATORS
//------------------------------------------------------------------------------
// Display comprehensive market information in top-right dashboard
// Shows RSI, current session, and liquidity timing status

rsi_v = ta.rsi(close, 14)  // Calculate RSI for momentum analysis

// Build dashboard on the last bar only
if barstate.islast
    var tbl = table.new(position.top_right, 8, 1, bgcolor=color.new(#363a45, 100), border_width=1)
    
    // Determine current active trading session
    current_session = nyam ? "NY AM" : nypm ? "NY PM" : london ? "London" : asian ? "Asia" : sydney ? "Sydney" : "None"
    
    // Determine current liquidity timing event (uses dashboard variables that work on all timeframes)
    current_liq = londonCloseDash ? "London Close" : nyseOpenDash ? "NYSE Open" : nyOpenDash ? "NY Open" : preNYDash ? "Pre-NY" : londonOpenDash ? "London Open" : preLondonDash ? "Pre-London" : asianOpenDash ? "Asian Open" : preAsianDash ? "Pre-Asian" : "None"
    
    // Populate dashboard cells with market information
    // Row 0: Asset Information
    table.cell(tbl, 0, 0, "Asset", text_color=color.rgb(255, 255, 255, 50))  // Header
    table.cell(tbl, 1, 0, syminfo.ticker, text_color=color.blue)  // Symbol
    
    // Row 0: RSI Information
    table.cell(tbl, 2, 0, "RSI (14)", text_color=color.rgb(255, 255, 255, 50))  // Header
    table.cell(tbl, 3, 0, str.tostring(math.round(rsi_v, 2)), text_color=rsi_v > 70 ? color.red : rsi_v < 30 ? color.green : color.blue)  // Value with color coding
    
    // Row 0: Session Information
    table.cell(tbl, 4, 0, "Session", text_color=color.rgb(255, 255, 255, 50))  // Header
    table.cell(tbl, 5, 0, current_session, text_color=color.blue)  // Current session
    
    // Row 0: Liquidity Information
    table.cell(tbl, 6, 0, "Volume", text_color=color.rgb(255, 255, 255, 50))  // Header
    table.cell(tbl, 7, 0, current_liq, text_color=color.purple)  // Current liquidity event (shows on all timeframes)
