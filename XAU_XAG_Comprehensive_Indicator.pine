//@version=6
indicator("XAU/XAG Comprehensive Trading Indicator", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500, max_bars_back=500)

//------------------------------------------------------------------------------
// Settings
//------------------------------------------------------------------------------{

// Session Settings
grp_session = "🕐 Session Settings"
show_sessions = input.bool(true, "Show Sessions", group=grp_session)
london_session = input.string('0800-1700', "London Session", group=grp_session)
newyork_session = input.string('1300-2200', "New York Session", group=grp_session)
asian_session = input.string('2300-0800', "Asian Session", group=grp_session)
london_color = input.color(color.new(#00bcd4, 90), "London Color", group=grp_session)
newyork_color = input.color(color.new(#ff5d00, 90), "New York Color", group=grp_session)
asian_color = input.color(color.new(#e91e63, 90), "Asian Color", group=grp_session)

// Order Block Settings
grp_ob = "📦 Order Block Settings"
show_ob = input.bool(true, "Show Order Blocks", group=grp_ob)
ob_swing_length = input.int(5, "Swing Detection Length", 3, 10, group=grp_ob)
ob_mitigation_price = input.string("Closing Price", "Mitigation Price", options=["Closing Price", "Wick"], group=grp_ob)
ob_use_body = input.bool(false, "Use Candle Body in Detection", group=grp_ob)
ob_remove_mitigated = input.bool(true, "Remove Mitigated Order Blocks", group=grp_ob)
ob_extend = input.bool(true, "Extend Order Blocks", group=grp_ob)
ob_display = input.string("First", "Display Order Blocks", options=["All", "First", "Last"], group=grp_session)
ob_bullish_color = input.color(color.new(#2157f3, 80), "Bullish OB Color", group=grp_ob)
ob_bearish_color = input.color(color.new(#ff5d00, 80), "Bearish OB Color", group=grp_ob)
ob_show_text = input.bool(true, "Show Order Blocks Text", group=grp_ob)

// Fair Value Gap Settings
grp_fvg = "⚡ Fair Value Gap Settings"
show_fvg = input.bool(true, "Show FVGs", group=grp_fvg)
fvg_atr_filter = input.float(1.2, "FVG ATR Filter", 0.0, 5.0, step=0.1, group=grp_fvg)
fvg_remove_mitigated = input.bool(true, "Remove Mitigated FVGs", group=grp_fvg)
fvg_extend = input.bool(true, "Extend FVGs", group=grp_fvg)
fvg_display = input.string("First", "Display FVGs", options=["All", "First", "Last"], group=grp_fvg)
fvg_bullish_color = input.color(color.new(#4caf50, 80), "Bullish FVG Color", group=grp_fvg)
fvg_bearish_color = input.color(color.new(#ff5d00, 80), "Bearish FVG Color", group=grp_fvg)
fvg_show_text = input.bool(true, "Show FVG Text", group=grp_fvg)

// Market Structure Shift Settings
grp_mss = "🔄 Market Structure Shifts"
show_mss = input.bool(false, "Show Market Structure Shifts", group=grp_mss)
mss_length = input.int(7, "MSS Detection Length", 1, 20, group=grp_mss)
mss_display = input.string("First", "Display MSS", options=["All", "First", "Last"], group=grp_mss)
mss_bullish_color = input.color(color.new(color.teal, 0), "Bullish MSS Color", group=grp_mss)
mss_bearish_color = input.color(color.new(color.red, 0), "Bearish MSS Color", group=grp_mss)
mss_show_text = input.bool(true, "Show MSS Text", group=grp_mss)

// Moving Averages Settings
grp_ma = "📈 Moving Averages"
show_ma = input.bool(true, "Show Moving Averages", group=grp_ma)
show_ema21 = input.bool(true, "Show 21 EMA", group=grp_ma)
show_sma50 = input.bool(true, "Show 50 SMA", group=grp_ma)
show_sma200 = input.bool(true, "Show 200 SMA", group=grp_ma)
ema21_color = input.color(color.yellow, "21 EMA Color", group=grp_ma)
sma50_color = input.color(color.blue, "50 SMA Color", group=grp_ma)
sma200_color = input.color(color.red, "200 SMA Color", group=grp_ma)

// Bollinger Bands Settings
grp_bb = "🎯 Bollinger Bands"
show_bb = input.bool(true, "Show Bollinger Bands", group=grp_bb)
bb_length = input.int(20, "BB Length", 5, 50, group=grp_bb)
bb_mult = input.float(2.0, "BB Multiplier", 1.0, 3.0, step=0.1, group=grp_bb)
bb_color = input.color(color.purple, "BB Color", group=grp_bb)

// MACD Settings
grp_macd = "📊 MACD Settings"
show_macd = input.bool(true, "Show MACD", group=grp_macd)
macd_fast = input.int(12, "MACD Fast Length", 5, 50, group=grp_macd)
macd_slow = input.int(26, "MACD Slow Length", 10, 100, group=grp_macd)
macd_signal = input.int(9, "MACD Signal Length", 5, 20, group=grp_macd)

// RSI Settings
grp_rsi = "💹 RSI Settings"
show_rsi = input.bool(true, "Show RSI", group=grp_rsi)
rsi_length = input.int(14, "RSI Length", 5, 50, group=grp_rsi)
rsi_oversold = input.int(30, "RSI Oversold Level", 10, 40, group=grp_rsi)
rsi_mid = input.int(50, "RSI Middle Level", 40, 60, group=grp_rsi)
rsi_overbought = input.int(70, "RSI Overbought Level", 60, 90, group=grp_rsi)

//------------------------------------------------------------------------------
// User Defined Types
//------------------------------------------------------------------------------{

type bar
    float o = open
    float h = high
    float l = low
    float c = close
    int   t = time
    int   i = bar_index

type OB
    float top  = na
    float btm  = na
    int   obI  = bar_index
    box   bxOB
    bool  ext  = true

type FVG
    box   bx
    bool  e

type swing
    float y = na
    int   i = na
    bool  x = false

type pivotPoint
    float  h
    int    hi
    bool   hx 
    float  l
    int    li
    bool   lx

type MSS
    line  ln
    box   bx

//------------------------------------------------------------------------------
// Variables
//------------------------------------------------------------------------------{

bar b = bar.new()
tfM = timeframe.multiplier

// Session detection
london_active = not na(time(timeframe.period, london_session, 'UTC-5')) and show_sessions
newyork_active = not na(time(timeframe.period, newyork_session, 'UTC-5')) and show_sessions
asian_active = not na(time(timeframe.period, asian_session, 'UTC-5')) and show_sessions
in_session = london_active or newyork_active or asian_active

// Arrays for Order Blocks
var bOB = array.new<OB>(0)
var aOB = array.new<OB>(0)

// Arrays for FVGs
var bFVG = array.new<FVG>(0)
var aFVG = array.new<FVG>(0)

// Arrays for Market Structure Shifts
var bMSS = array.new<MSS>(0)
var aMSS = array.new<MSS>(0)

// Pivot points for swing detection
var pivotPoint pp = pivotPoint.new()
var shift = 0

// FVG ATR calculation
fvgATR = nz(ta.atr(144)) * fvg_atr_filter

//------------------------------------------------------------------------------
// Functions / Methods
//------------------------------------------------------------------------------{

// Swing detection function
swings(_l) =>
    int os = 0
    swing top = swing.new(na, na)
    swing btm = swing.new(na, na)
    
    upper = ta.highest(_l)
    lower = ta.lowest(_l)

    os := high[_l] > upper ? 0 : low[_l] < lower ? 1 : os

    if os == 0 and os[1] != 0
        top := swing.new(high[_l], bar_index[_l])
    
    if os == 1 and os[1] != 1
        btm := swing.new(low[_l], bar_index[_l])

    [top, btm]

// Order Block detection function
detect_order_blocks(_s, _o, _h, _l, _c, _i, _t, _st, _sb, _mx, _mn) =>
    int sbI = 0
    bool xb = false
    bool xa = false

    if _s and not _s[1]
        sbI := _i, xb := true, xa := true
        
        if ob_extend
            if bOB.size() > 0
                for i = bOB.size() - 1 to 0
                    bOB.remove(i)
            if aOB.size() > 0
                for i = aOB.size() - 1 to 0
                    aOB.remove(i)

    if _s
        if _c[1] > _st.y and not _st.x and _st.i >= sbI
            _st.x := true

            minima = _mx[1]
            maxima = _mn[1]
            sBT = _t[1]

            for i = 1 to (_i - _st.i) - 1
                minima := math.min(_mn[i], minima)
                maxima := minima == _mn[i] ? _mx[i] : maxima
                sBT := minima == _mn[i] ? _t[i] : sBT
            
            bOB.unshift(OB.new(maxima, minima, sBT, 
                         box.new(na, na, na, na, color(na), xloc = xloc.bar_time, text = ob_show_text ? 'OB' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(ob_bullish_color, 0)))) 

        if _c[1] < _sb.y and not _sb.x and _st.i >= sbI 
            _sb.x := true

            minima = _mn[1]
            maxima = _mx[1]
            sBT = _t[1]

            for i = 1 to (_i - _sb.i) - 1
                maxima := math.max(_mx[i], maxima)
                minima := maxima == _mx[i] ? _mn[i] : minima
                sBT := maxima == _mx[i] ? _t[i] : sBT

            aOB.unshift(OB.new(maxima, minima, sBT, 
                         box.new(na, na, na, na, color(na), xloc = xloc.bar_time, text = ob_show_text ? 'OB' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(ob_bearish_color, 0)))) 

    if ob_extend ? true : _s
        if bOB.size() > 0
            for i = bOB.size() - 1 to 0
                ob = bOB.get(i)

                if ob_remove_mitigated 
                    if not ob.ext
                        ob.bxOB.delete()

                if ob_display == 'First' ? i == bOB.size() - 1 : true
                    ob.bxOB.set_lefttop(ob.obI, ob.top)
                    ob.bxOB.set_rightbottom(_t, ob.btm)
                    ob.bxOB.set_bgcolor(ob_display == 'Last' ? i == 0 ? ob_bullish_color : color(na) : ob_bullish_color)
                    ob.bxOB.set_text_color(ob_display == 'Last' ? i == 0 ? color.new(ob_bullish_color, 0) : color(na) : color.new(ob_bullish_color, 0))

                mitigation_price = ob_mitigation_price == 'Closing Price' ? (close[1]) : (low[1])
                if math.min(mitigation_price, (open[1])) < ob.btm
                    if ob_display == 'First'
                        ob.bxOB.set_right((time[1]))
                    ob.ext := false

        if aOB.size() > 0
            for i = aOB.size() - 1 to 0
                ob = aOB.get(i)

                if ob_remove_mitigated 
                    if not ob.ext
                        ob.bxOB.delete()

                if ob_display == 'First' ? i == aOB.size() - 1 : true
                    ob.bxOB.set_lefttop(ob.obI, ob.top)
                    ob.bxOB.set_rightbottom(_t, ob.btm)
                    ob.bxOB.set_bgcolor(ob_display == 'Last' ? i == 0 ? ob_bearish_color : color(na) : ob_bearish_color)
                    ob.bxOB.set_text_color(ob_display == 'Last' ? i == 0 ? color.new(ob_bearish_color, 0) : color(na) : color.new(ob_bearish_color, 0))

                mitigation_price = ob_mitigation_price == 'Closing Price' ? (close[1]) : (high[1])
                if math.max(mitigation_price, (open[1])) > ob.top
                    if ob_display == 'First'
                        ob.bxOB.set_right((time[1]))
                    ob.ext := false

// Fair Value Gap detection function
detect_fvg(_s, _h, _l, _c, _i, _atr) =>
    xb = false
    xa = false

    if _s and not _s[1]
        xb := true, xa := true
        if fvg_extend
            if bFVG.size() > 0
                for i = bFVG.size() - 1 to 0
                    bFVG.remove(i)
            if aFVG.size() > 0
                for i = aFVG.size() - 1 to 0
                    aFVG.remove(i)

    bullG = (low[1]) > (high[1])
    bearG = (high[1]) < (low[1])

    if _s
        bull  = (_l - (high[2])) > _atr and _l > (high[2]) and (close[1]) > (high[2]) and not (bullG or bullG[1])

        if bull and xb
            bFVG.unshift(FVG.new(box.new(_i - 1, _l, _i, (high[2]), na, bgcolor = fvg_bullish_color, text = fvg_show_text ? 'FVG' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(fvg_bullish_color, 0)), true))
            
            if fvg_display == 'First'
                xb := false
        
            if bFVG.size() > 1
                if fvg_display == 'Last'
                    fvg = bFVG.pop()
                    fvg.bx.delete()

        bear  = ((low[2]) - _h) > _atr and _h < (low[2]) and (close[1]) < (low[2]) and not (bearG or bearG[1])

        if bear and xa
            aFVG.unshift(FVG.new(box.new(_i - 1, (low[2]), _i, _h, na, bgcolor = fvg_bearish_color, text = fvg_show_text ? 'FVG' : '', text_size = size.tiny, text_halign = text.align_center, text_valign = text.align_center, text_color = color.new(fvg_bearish_color, 0)), true))

            if fvg_display == 'First'
                xa := false

            if aFVG.size() > 1
                if fvg_display == 'Last'
                    fvg = aFVG.pop()
                    fvg.bx.delete()

    if fvg_extend ? true : _s
        if bFVG.size() > 0 
            for i = bFVG.size() - 1 to 0
                fvg  = bFVG.get(i)
                fvgB = fvg.bx.get_bottom()

                if fvg.e
                    isBelowBottom = _l < fvgB
                    if isBelowBottom
                        fvg.bx.set_right(_i)
                        if fvg_remove_mitigated
                            fvg.bx.delete()
                        fvg.e := false
                    else
                        fvg.bx.set_right(_i)
                else
                    fvg.bx.set_right(_i)

        if aFVG.size() > 0
            for i = aFVG.size() - 1 to 0
                fvg  = aFVG.get(i)
                fvgT = fvg.bx.get_top()

                if fvg.e
                    isAboveTop = _h > fvgT
                    if isAboveTop
                        fvg.bx.set_right(_i)
                        if fvg_remove_mitigated
                            fvg.bx.delete()
                        fvg.e := false
                    else
                        fvg.bx.set_right(_i)
                else
                    fvg.bx.set_right(_i)


//------------------------------------------------------------------------------
// Calculations
//------------------------------------------------------------------------------{

// Swing detection for Order Blocks
[top, btm] = swings(ob_swing_length)
max = ob_use_body ? math.max(b.c, b.o) : b.h
min = ob_use_body ? math.min(b.c, b.o) : b.l

// Order Block detection
if show_ob
    detect_order_blocks(in_session, b.o, b.h, b.l, b.c, b.i, b.t, top, btm, max, min)

// Fair Value Gap detection
if show_fvg
    detect_fvg(in_session, b.h, b.l, b.c, b.i, fvgATR)

// Market Structure Shift detection
pp_h = ta.pivothigh(mss_length, mss_length)
pp_l = ta.pivotlow(mss_length, mss_length)

if not na(pp_h)
    pp.h  := pp_h
    pp.hx := false
    pp.hi := b.i - mss_length

if not na(pp_l)
    pp.l  := pp_l
    pp.lx := false
    pp.li := b.i - mss_length

if not in_session
    pp.l := 0
    pp.h := 10e8
    shift := 0

    if bMSS.size() > 0
        for i = bMSS.size() - 1 to 0
            bMSS.remove(i)

    if aMSS.size() > 0
        for i = aMSS.size() - 1 to 0
            aMSS.remove(i)

if show_mss and in_session
    if (close[1]) > pp.h and not pp.hx
        pp.hx := true

        if shift == -1 or shift == 0
            if (mss_display == 'First' ? bMSS.size() < 1 : true)
                bMSS.unshift(MSS.new(line.new(pp.hi, pp.h, b.i - 1, pp.h, color = mss_bullish_color), 
                 box.new(pp.hi, pp.h, b.i - 1, pp.h, text = 'CHoCH', text_size = size.tiny, text_halign = text.align_left, text_valign = text.align_bottom, text_color = mss_show_text ? mss_bullish_color : color(na), bgcolor = color(na), border_color = color(na))
                 ))

            if bMSS.size() > 1
                if mss_display == 'Last'
                    mss = bMSS.pop()
                    mss.ln.delete(), mss.bx.delete()

        shift := 1

    if (close[1]) < pp.l and not pp.lx
        pp.lx := true

        if shift == 1 or shift == 0
            if (mss_display == 'First' ? aMSS.size() < 1 : true)
                aMSS.unshift(MSS.new(line.new(pp.li, pp.l, b.i - 1, pp.l, color = mss_bearish_color), 
                 box.new(pp.li, pp.l, b.i - 1, pp.l, text = 'CHoCH', text_size = size.tiny, text_halign = text.align_left, text_valign = text.align_top, text_color = mss_show_text ? mss_bearish_color : color(na), bgcolor = color(na), border_color = color(na))
                 ))

            if aMSS.size() > 1
                if mss_display == 'Last'
                    mss = aMSS.pop()
                    mss.ln.delete(), mss.bx.delete()

        shift := -1

// Session backgrounds
bgcolor(london_active ? london_color : na)
bgcolor(newyork_active ? newyork_color : na)
bgcolor(asian_active ? asian_color : na)

//------------------------------------------------------------------------------
// Traditional Indicators Calculations
//------------------------------------------------------------------------------{

// Moving Averages
ema21 = ta.ema(close, 21)
sma50 = ta.sma(close, 50)
sma200 = ta.sma(close, 200)

// Bollinger Bands
bb_basis = ta.sma(close, bb_length)
bb_dev = bb_mult * ta.stdev(close, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

// MACD
[macd_line, signal_line, macd_hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)

// RSI
rsi_value = ta.rsi(close, rsi_length)

// ═══════════════════════════════════════════════════════════════════════════════
// 🎨 PLOTTING - MAIN CHART
// ═══════════════════════════════════════════════════════════════════════════════

// Moving Averages
plot(show_ema21 ? ema21 : na, color=ema21_color, linewidth=2, title="21 EMA")
plot(show_sma50 ? sma50 : na, color=sma50_color, linewidth=2, title="50 SMA")
plot(show_sma200 ? sma200 : na, color=sma200_color, linewidth=2, title="200 SMA")

// Bollinger Bands
plot(show_bb ? bb_upper : na, color=bb_color, linewidth=1, title="BB Upper")
plot(show_bb ? bb_basis : na, color=color.new(bb_color, 50), linewidth=1, title="BB Basis")
plot(show_bb ? bb_lower : na, color=bb_color, linewidth=1, title="BB Lower")

bb_upper_plot = plot(show_bb ? bb_upper : na, color=bb_color, linewidth=1, title="BB Upper")
bb_lower_plot = plot(show_bb ? bb_lower : na, color=bb_color, linewidth=1, title="BB Lower")
fill(bb_upper_plot, bb_lower_plot, color=color.new(bb_color, 90), title="BB Fill")

// ═══════════════════════════════════════════════════════════════════════════════
// 📊 INDICATOR WINDOW
// ═══════════════════════════════════════════════════════════════════════════════

// Create separate pane for indicators
macd_pane = show_macd ? 1 : 0
rsi_pane = show_rsi ? 2 : 0

// MACD Plot
macd_plot = plot(show_macd ? macd_line : na, color=color.blue, linewidth=2, title="MACD Line")
signal_plot = plot(show_macd ? signal_line : na, color=color.red, linewidth=2, title="Signal Line")
hist_plot = plot(show_macd ? macd_hist : na, color=macd_hist > 0 ? color.green : color.red, 
                 style=plot.style_columns, title="MACD Histogram")
fill(macd_plot, signal_plot, color.new(color.blue, 90), title="MACD Fill")

// RSI Plot
rsi_plot = plot(show_rsi ? rsi_value : na, color=color.purple, linewidth=2, title="RSI")
    
// RSI Levels
rsi_overbought_line = hline(show_rsi ? rsi_overbought : na, "RSI Overbought", color=color.red, linestyle=hline.style_dashed)
rsi_mid_line = hline(show_rsi ? rsi_mid : na, "RSI Middle", color=color.gray, linestyle=hline.style_dotted)
rsi_oversold_line = hline(show_rsi ? rsi_oversold : na, "RSI Oversold", color=color.green, linestyle=hline.style_dashed)
    
// RSI Zone Fills - Note: fill() doesn't work with plot objects, so we'll skip zone fills for now
// fill(rsi_plot, rsi_overbought_line, color.new(color.red, 90), title="Overbought Zone")
// fill(rsi_plot, rsi_oversold_line, color.new(color.green, 90), title="Oversold Zone")

// ═══════════════════════════════════════════════════════════════════════════════
// 🔔 ALERTS & SIGNALS
// ═══════════════════════════════════════════════════════════════════════════════

// Alert conditions
ma_bullish_cross = ta.crossover(ema21, sma50)
ma_bearish_cross = ta.crossunder(ema21, sma50)

rsi_overbought_signal = rsi_value > rsi_overbought
rsi_oversold_signal = rsi_value < rsi_oversold

macd_bullish_cross = ta.crossover(macd_line, signal_line)
macd_bearish_cross = ta.crossunder(macd_line, signal_line)

// Plot signals on chart
plotshape(ma_bullish_cross and show_ma, title="MA Bullish Cross", style=shape.triangleup, 
          location=location.belowbar, color=color.green, size=size.small)
plotshape(ma_bearish_cross and show_ma, title="MA Bearish Cross", style=shape.triangledown, 
          location=location.abovebar, color=color.red, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// 📝 INFORMATION TABLE
// ═══════════════════════════════════════════════════════════════════════════════

if barstate.islast
    var table info_table = table.new(position.top_right, 2, 7, bgcolor=color.white, border_width=1)
    
    table.cell(info_table, 0, 0, "Indicator", bgcolor=color.blue, text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "Value", bgcolor=color.blue, text_color=color.white, text_size=size.small)
    
    if show_ma
        table.cell(info_table, 0, 1, "21 EMA", text_color=color.black, text_size=size.small)
        table.cell(info_table, 1, 1, str.tostring(math.round(ema21, 2)), text_color=color.black, text_size=size.small)
        
        table.cell(info_table, 0, 2, "50 SMA", text_color=color.black, text_size=size.small)
        table.cell(info_table, 1, 2, str.tostring(math.round(sma50, 2)), text_color=color.black, text_size=size.small)
    
    if show_rsi
        table.cell(info_table, 0, 3, "RSI", text_color=color.black, text_size=size.small)
        rsi_color = rsi_value > rsi_overbought ? color.red : rsi_value < rsi_oversold ? color.green : color.gray
        table.cell(info_table, 1, 3, str.tostring(math.round(rsi_value, 2)), text_color=rsi_color, text_size=size.small)
    
    if show_macd
        table.cell(info_table, 0, 4, "MACD", text_color=color.black, text_size=size.small)
        macd_color = macd_line > signal_line ? color.green : color.red
        table.cell(info_table, 1, 4, str.tostring(math.round(macd_line, 4)), text_color=macd_color, text_size=size.small)
    
    if show_bb
        bb_width = (bb_upper - bb_lower) / bb_basis * 100
        table.cell(info_table, 0, 5, "BB Width %", text_color=color.black, text_size=size.small)
        table.cell(info_table, 1, 5, str.tostring(math.round(bb_width, 2)), text_color=color.black, text_size=size.small)
    
    // Session info
    current_session = london_active ? "London" : newyork_active ? "New York" : asian_active ? "Asian" : "None"
    table.cell(info_table, 0, 6, "Session", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 6, current_session, text_color=color.black, text_size=size.small)
