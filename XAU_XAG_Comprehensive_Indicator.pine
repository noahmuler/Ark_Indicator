//@version=5
indicator("XAU/XAG Comprehensive Trading Indicator", overlay=true, max_boxes_count=500, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════════════════════
// 📋 SETTINGS & INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

// Session Settings
grp_session = "🕐 Session Settings"
show_sessions = input.bool(true, "Show Sessions", group=grp_session)
london_session = input.bool(true, "London Session", group=grp_session)
newyork_session = input.bool(true, "New York Session", group=grp_session)
asian_session = input.bool(true, "Asian Session", group=grp_session)
london_color = input.color(color.new(color.blue, 90), "London Color", group=grp_session)
newyork_color = input.color(color.new(color.green, 90), "New York Color", group=grp_session)
asian_color = input.color(color.new(color.orange, 90), "Asian Color", group=grp_session)

// Order Block Settings
grp_ob = "📦 Order Block Settings"
show_ob = input.bool(true, "Show Order Blocks", group=grp_ob)
ob_bullish_color = input.color(color.new(color.green, 60), "Bullish OB Color", group=grp_ob)
ob_bearish_color = input.color(color.new(color.red, 60), "Bearish OB Color", group=grp_ob)
ob_sensitivity = input.int(3, "OB Sensitivity (1-5)", 1, 5, group=grp_ob)

// Fair Value Gap Settings
grp_fvg = "⚡ Fair Value Gap Settings"
show_fvg = input.bool(true, "Show FVGs", group=grp_fvg)
fvg_bullish_color = input.color(color.new(color.green, 80), "Bullish FVG Color", group=grp_fvg)
fvg_bearish_color = input.color(color.new(color.red, 80), "Bearish FVG Color", group=grp_fvg)
fvg_min_size = input.float(0.1, "Minimum FVG Size (% of price)", 0.01, 1.0, step=0.01, group=grp_fvg)

// Moving Averages Settings
grp_ma = "📈 Moving Averages"
show_ma = input.bool(true, "Show Moving Averages", group=grp_ma)
show_ema21 = input.bool(true, "Show 21 EMA", group=grp_ma)
show_sma50 = input.bool(true, "Show 50 SMA", group=grp_ma)
show_sma200 = input.bool(true, "Show 200 SMA", group=grp_ma)
ema21_color = input.color(color.yellow, "21 EMA Color", group=grp_ma)
sma50_color = input.color(color.blue, "50 SMA Color", group=grp_ma)
sma200_color = input.color(color.red, "200 SMA Color", group=grp_ma)

// Bollinger Bands Settings
grp_bb = "🎯 Bollinger Bands"
show_bb = input.bool(true, "Show Bollinger Bands", group=grp_bb)
bb_length = input.int(20, "BB Length", 5, 50, group=grp_bb)
bb_mult = input.float(2.0, "BB Multiplier", 1.0, 3.0, step=0.1, group=grp_bb)
bb_color = input.color(color.purple, "BB Color", group=grp_bb)

// MACD Settings
grp_macd = "📊 MACD Settings"
show_macd = input.bool(true, "Show MACD", group=grp_macd)
macd_fast = input.int(12, "MACD Fast Length", 5, 50, group=grp_macd)
macd_slow = input.int(26, "MACD Slow Length", 10, 100, group=grp_macd)
macd_signal = input.int(9, "MACD Signal Length", 5, 20, group=grp_macd)

// RSI Settings
grp_rsi = "💹 RSI Settings"
show_rsi = input.bool(true, "Show RSI", group=grp_rsi)
rsi_length = input.int(14, "RSI Length", 5, 50, group=grp_rsi)
rsi_oversold = input.int(30, "RSI Oversold Level", 10, 40, group=grp_rsi)
rsi_mid = input.int(50, "RSI Middle Level", 40, 60, group=grp_rsi)
rsi_overbought = input.int(70, "RSI Overbought Level", 60, 90, group=grp_rsi)

// ═══════════════════════════════════════════════════════════════════════════════
// 🔧 HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Function to check if current time is within session
is_in_session(start_hour, start_min, end_hour, end_min) =>
    current_time = time("1")
    current_hour = hour(current_time)
    current_min = minute(current_time)
    current_total = current_hour * 60 + current_min
    start_total = start_hour * 60 + start_min
    end_total = end_hour * 60 + end_min
    
    if start_total <= end_total
        current_total >= start_total and current_total <= end_total
    else
        current_total >= start_total or current_total <= end_total

// Function to detect Order Blocks
detect_order_blocks(sensitivity) =>
    var array<box> bullish_obs = array.new<box>()
    var array<box> bearish_obs = array.new<box>()
    
    // Bullish Order Block: Strong bearish candle followed by strong bullish move
    if close > open and close[1] < open[1] and (close - open) > (open[1] - close[1]) * sensitivity / 3
        if array.size(bullish_obs) > 20
            box.delete(array.shift(bullish_obs))
        ob_box = box.new(bar_index, low, bar_index + 10, high, 
                         border_color=ob_bullish_color, bgcolor=ob_bullish_color)
        array.push(bullish_obs, ob_box)
    
    // Bearish Order Block: Strong bullish candle followed by strong bearish move
    if close < open and close[1] > open[1] and (open - close) > (close[1] - open[1]) * sensitivity / 3
        if array.size(bearish_obs) > 20
            box.delete(array.shift(bearish_obs))
        ob_box = box.new(bar_index, low, bar_index + 10, high, 
                         border_color=ob_bearish_color, bgcolor=ob_bearish_color)
        array.push(bearish_obs, ob_box)

// Function to detect Fair Value Gaps
detect_fvg() =>
    var array<box> bullish_fvgs = array.new<box>()
    var array<box> bearish_fvgs = array.new<box>()
    
    // Bullish FVG: Gap between candle 2 high and candle 3 low
    if high[2] < low[3]
        gap_size = (low[3] - high[2]) / close * 100
        if gap_size >= fvg_min_size
            if array.size(bullish_fvgs) > 30
                box.delete(array.shift(bullish_fvgs))
            fvg_box = box.new(bar_index[3], high[2], bar_index[2], low[3], 
                             border_color=fvg_bullish_color, bgcolor=fvg_bullish_color)
            array.push(bullish_fvgs, fvg_box)
    
    // Bearish FVG: Gap between candle 2 low and candle 3 high
    if low[2] > high[3]
        gap_size = (low[2] - high[3]) / close * 100
        if gap_size >= fvg_min_size
            if array.size(bearish_fvgs) > 30
                box.delete(array.shift(bearish_fvgs))
            fvg_box = box.new(bar_index[3], low[2], bar_index[2], high[3], 
                             border_color=fvg_bearish_color, bgcolor=fvg_bearish_color)
            array.push(bearish_fvgs, fvg_box)

// ═══════════════════════════════════════════════════════════════════════════════
// 📈 CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Moving Averages
ema21 = ta.ema(close, 21)
sma50 = ta.sma(close, 50)
sma200 = ta.sma(close, 200)

// Bollinger Bands
bb_basis = ta.sma(close, bb_length)
bb_dev = bb_mult * ta.stdev(close, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

// MACD
[macd_line, signal_line, macd_hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)

// RSI
rsi_value = ta.rsi(close, rsi_length)

// ═══════════════════════════════════════════════════════════════════════════════
// 🎨 PLOTTING - MAIN CHART
// ═══════════════════════════════════════════════════════════════════════════════

// Session Backgrounds
if show_sessions
    // London Session (08:00 - 17:00 UTC)
    if london_session and is_in_session(8, 0, 17, 0)
        bgcolor(london_color)
    
    // New York Session (13:00 - 22:00 UTC)
    if newyork_session and is_in_session(13, 0, 22, 0)
        bgcolor(newyork_color)
    
    // Asian Session (23:00 - 08:00 UTC)
    if asian_session and is_in_session(23, 0, 8, 0)
        bgcolor(asian_color)

// Moving Averages
if show_ma
    plot(show_ema21 ? ema21 : na, color=ema21_color, linewidth=2, title="21 EMA")
    plot(show_sma50 ? sma50 : na, color=sma50_color, linewidth=2, title="50 SMA")
    plot(show_sma200 ? sma200 : na, color=sma200_color, linewidth=2, title="200 SMA")

// Bollinger Bands
if show_bb
    plot(bb_upper, color=bb_color, linewidth=1, title="BB Upper")
    plot(bb_basis, color.new(bb_color, 50), linewidth=1, title="BB Basis")
    plot(bb_lower, color=bb_color, linewidth=1, title="BB Lower")
    fill(plot1=bb_upper, plot2=bb_lower, color=color.new(bb_color, 90), title="BB Fill")

// Order Blocks and FVGs
if show_ob
    detect_order_blocks(ob_sensitivity)

if show_fvg
    detect_fvg()

// ═══════════════════════════════════════════════════════════════════════════════
// 📊 INDICATOR WINDOW
// ═══════════════════════════════════════════════════════════════════════════════

// Create separate pane for indicators
macd_pane = show_macd ? 1 : 0
rsi_pane = show_rsi ? 2 : 0

// MACD Plot
if show_macd
    macd_plot = plot(macd_line, color=color.blue, linewidth=2, title="MACD Line", pane=macd_pane)
    signal_plot = plot(signal_line, color=color.red, linewidth=2, title="Signal Line", pane=macd_pane)
    hist_plot = plot(macd_hist, color=macd_hist > 0 ? color.green : color.red, 
                     style=plot.style_columns, title="MACD Histogram", pane=macd_pane)
    fill(macd_plot, signal_plot, color.new(color.blue, 90), title="MACD Fill")

// RSI Plot
if show_rsi
    rsi_plot = plot(rsi_value, color=color.purple, linewidth=2, title="RSI", pane=rsi_pane)
    
    // RSI Levels
    hline(rsi_overbought, "RSI Overbought", color=color.red, linestyle=hline.style_dashed, pane=rsi_pane)
    hline(rsi_mid, "RSI Middle", color=color.gray, linestyle=hline.style_dotted, pane=rsi_pane)
    hline(rsi_oversold, "RSI Oversold", color=color.green, linestyle=hline.style_dashed, pane=rsi_pane)
    
    // RSI Zone Fills
    fill(rsi_plot, hline(rsi_overbought), color.new(color.red, 90), title="Overbought Zone", pane=rsi_pane)
    fill(rsi_plot, hline(rsi_oversold), color.new(color.green, 90), title="Oversold Zone", pane=rsi_pane)

// ═══════════════════════════════════════════════════════════════════════════════
// 🔔 ALERTS & SIGNALS (Optional Enhancement)
// ═══════════════════════════════════════════════════════════════════════════════

// Example alert conditions (can be expanded)
ma_bullish_cross = ta.crossover(ema21, sma50)
ma_bearish_cross = ta.crossunder(ema21, sma50)

rsi_overbought_signal = rsi_value > rsi_overbought
rsi_oversold_signal = rsi_value < rsi_oversold

macd_bullish_cross = ta.crossover(macd_line, signal_line)
macd_bearish_cross = ta.crossunder(macd_line, signal_line)

// Plot signals on chart (optional)
plotshape(ma_bullish_cross and show_ma, title="MA Bullish Cross", style=shape.triangleup, 
          location=location.belowbar, color=color.green, size=size.small)
plotshape(ma_bearish_cross and show_ma, title="MA Bearish Cross", style=shape.triangledown, 
          location=location.abovebar, color=color.red, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// 📝 TABLE DISPLAY (Information Panel)
// ═══════════════════════════════════════════════════════════════════════════════

if barstate.islast
    var table info_table = table.new(position.top_right, 2, 6, bgcolor=color.white, border_width=1)
    
    table.cell(info_table, 0, 0, "Indicator", bgcolor=color.blue, text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "Value", bgcolor=color.blue, text_color=color.white, text_size=size.small)
    
    if show_ma
        table.cell(info_table, 0, 1, "21 EMA", text_color=color.black, text_size=size.small)
        table.cell(info_table, 1, 1, str.tostring(math.round(ema21, 2)), text_color=color.black, text_size=size.small)
        
        table.cell(info_table, 0, 2, "50 SMA", text_color=color.black, text_size=size.small)
        table.cell(info_table, 1, 2, str.tostring(math.round(sma50, 2)), text_color=color.black, text_size=size.small)
    
    if show_rsi
        table.cell(info_table, 0, 3, "RSI", text_color=color.black, text_size=size.small)
        rsi_color = rsi_value > rsi_overbought ? color.red : rsi_value < rsi_oversold ? color.green : color.gray
        table.cell(info_table, 1, 3, str.tostring(math.round(rsi_value, 2)), text_color=rsi_color, text_size=size.small)
    
    if show_macd
        table.cell(info_table, 0, 4, "MACD", text_color=color.black, text_size=size.small)
        macd_color = macd_line > signal_line ? color.green : color.red
        table.cell(info_table, 1, 4, str.tostring(math.round(macd_line, 4)), text_color=macd_color, text_size=size.small)
    
    if show_bb
        bb_width = (bb_upper - bb_lower) / bb_basis * 100
        table.cell(info_table, 0, 5, "BB Width %", text_color=color.black, text_size=size.small)
        table.cell(info_table, 1, 5, str.tostring(math.round(bb_width, 2)), text_color=color.black, text_size=size.small)
